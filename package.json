{
  "name": "ai-task-bench",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "bench": "bun run src/cli/main.ts",
    "check": "bun run test && bun run typecheck && bun run lint && bun run validate:benchmark",
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.check.json",
    "lint": "oxlint src/ scripts/",
    "validate:benchmark": "bun run scripts/validate-benchmark.ts",
    "results": "bun run scripts/generate-results.ts",
    "grades": "bun run scripts/print-grades.ts",
    "web:data": "bun run scripts/build-web-data.ts",
    "web:dev": "bun run web:data && astro dev --root web",
    "web:build": "bun run web:data && astro build --root web",
    "web:preview": "astro preview --root web",
    "migrate:task-layout": "bun run scripts/migrate-task-layout.ts",
    "compact:sessions": "bun run scripts/compact-run-sessions.ts",
    "dev": "bun run src/cli/main.ts"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.0",
    "@tanstack/react-query": "^5.101.1",
    "@types/react-dom": "^19.2.3",
    "@visx/responsive": "^4.0.0",
    "@visx/xychart": "^4.0.0",
    "astro": "^7.0.3",
    "cac": "^6.7.14",
    "effect": "^4.0.0-beta.0",
    "ink": "^5.2.0",
    "marked": "^18.0.5",
    "react": "19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "oxlint": "^1.0.0",
    "typescript": "^5.7.0"
  }
}
